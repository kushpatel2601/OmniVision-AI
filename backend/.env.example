# MongoDB Atlas connection string
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=shelfiq

# Redis (optional – alerts fall back to in-memory if not set)
REDIS_URL=redis://localhost:6379

# App settings
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# YOLOv8 model — trained on full SKU-110k dataset
# Place yolov8m_sku_full.pt in the backend/ root directory
YOLO_WEIGHTS=yolov8m_sku_full.pt
YOLO_CONF=0.30     # confidence threshold (lower = more detections)
YOLO_IOU=0.45      # NMS IoU threshold

# Grid layout for position-based SKU inference (SKU-110k is single-class)
SHELF_ROWS=4
SHELF_COLS=8

# Email Alerts
ALERT_EMAIL=your_gmail@gmail.com
ALERT_EMAIL_PASSWORD=your_app_password
